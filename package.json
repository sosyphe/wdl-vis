{
  "name": "wdl-viewer",
  "version": "0.1.0",
  "description": "WDL workflow parser and visualizer Vue 3 component library",
  "type": "module",
  "main": "dist/vue-wdl-viewer.umd.js",
  "module": "dist/vue-wdl-viewer.es.js",
  "exports": {
    ".": {
      "import": "./dist/vue-wdl-viewer.es.js",
      "require": "./dist/vue-wdl-viewer.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode demo",
    "build:lib": "vite build",
    "build:demo": "vite build --mode demo",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.2",
    "vitest": "^1.0.0",
    "vue": "^3.4.0"
  }
}
